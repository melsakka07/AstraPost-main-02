# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# pnpm lockfile is tracked in this repo

# testing
/coverage
/playwright-report/
/test-results/
/.playwright-mcp

# logs
/logs/

# next.js
/.next/
/out/

# turbopack cache
.turbo/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# local tooling
.pnpm-store/
.trae/
.claude/
.cursor/
.vscode/

# other lockfiles
package-lock.json
yarn.lock

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# sentry
.sentryclirc
.sentry-build-plugin.json

# typescript
*.tsbuildinfo
next-env.d.ts

# uploads (user-generated content, not tracked)
public/uploads

# PWA generated files
public/sw.js
public/workbox-*.js
public/worker-*.js
public/sw.js.map
public/workbox-*.js.map
public/worker-*.js.map

.vercel
.env*.local

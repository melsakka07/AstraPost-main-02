# Database
POSTGRES_URL=postgresql://dev_user:dev_password@localhost:5432/postgres_dev

# Authentication - Better Auth
# Generate key using https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3000"

# X (Twitter) OAuth
# Create app at https://developer.twitter.com/en/portal/dashboard
# Ensure you enable "Read and Write" permissions and "Request email from users"
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# X (Twitter) API Bearer Token
# Used for importing public tweets (Inspiration feature)
# Get it from: https://developer.twitter.com/en/portal/dashboard -> Your App -> Keys and Tokens -> Bearer Token
TWITTER_BEARER_TOKEN=

# Security
# Comma-separated 32-byte keys (base64 or hex). First key is primary for encryption.
# Example (base64): TOKEN_ENCRYPTION_KEYS="3C4S0H3o8m0h+uD3T1N1a0bA0qJ3fN9mGQ2c0b2mW0Q=,OLDKEYBASE64..."
TOKEN_ENCRYPTION_KEYS=

# AI Integration via OpenRouter (text generation)
# Get your API key from: https://openrouter.ai/settings/keys
# View available models at: https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL="openai/gpt-4o"

# AI Image Generation via Replicate
# Get your API token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Replicate model identifiers — override to swap models without code changes
# Browse models at: https://replicate.com/explore
REPLICATE_MODEL_FAST="google/nano-banana-2"
REPLICATE_MODEL_PRO="google/nano-banana-pro"
REPLICATE_MODEL_FALLBACK="google/nano-banana"

# Queue (Redis)
REDIS_URL="redis://localhost:6379"

# Stripe Billing (Optional - for Pro plans)
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
STRIPE_PRICE_ID_AGENCY_MONTHLY=
STRIPE_PRICE_ID_AGENCY_ANNUAL=

# App URL (for production deployments)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# File storage (optional - using local storage by default)
# BLOB_READ_WRITE_TOKEN=

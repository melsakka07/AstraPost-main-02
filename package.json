    "@types/cheerio": "^0.22.35",
    "@types/twitter-text": "^3.1.10",
    "@vercel/blob": "^2.0.1",
    "ai": "^5.0.123",
    "better-auth": "^1.4.18",
    "bullmq": "^5.70.4",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "driver.js": "^1.4.0",
    "drizzle-orm": "^0.44.7",
    "emoji-picker-react": "^4.18.0",

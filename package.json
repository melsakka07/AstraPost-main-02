{
  "name": "astropost",
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "worker": "node --require dotenv/config --import tsx scripts/worker.ts",
    "tokens:rotate": "node --require dotenv/config --import tsx scripts/rotate-token-encryption.ts",
    "tokens:encrypt-access": "node --require dotenv/config --import tsx scripts/encrypt-x-access-tokens.ts",
    "smoke:e2e": "node --require dotenv/config --import tsx scripts/smoke-e2e.ts",
    "smoke:full": "node --require dotenv/config --import tsx scripts/smoke-full.ts",
    "esbuild:rebuild": "pnpm rebuild esbuild",
    "build": "pnpm run db:migrate && next build",
    "build:ci": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "npx tsx scripts/setup.ts",
    "env:check": "node -e \"require('./src/lib/env.ts').checkEnv()\" || echo 'Run with tsx: npx tsx -e \"import { checkEnv } from './src/lib/env'; checkEnv();\"'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:dev": "drizzle-kit push",
    "db:reset": "drizzle-kit drop && drizzle-kit push",
    "sync-template": "node create-agentic-app/scripts/sync-templates.js",
    "test": "vitest run",
    "test:e2e:ui": "playwright test tests/e2e/dashboard-layout.e2e.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.125",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@sentry/nextjs": "^10.43.0",
    "@types/cheerio": "^0.22.35",
    "@vercel/blob": "^2.0.1",
    "ai": "^5.0.123",
    "better-auth": "^1.4.18",
    "bullmq": "^5.70.4",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.7",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.539.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.17.2",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "twitter-api-v2": "^1.29.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "latest",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.5",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shadcn": "^3.7.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@types/react": "19.2.5",
      "@types/react-dom": "19.2.3"
    }
  }
}

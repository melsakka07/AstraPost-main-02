{
  "name": "astrapost",
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "worker": "node --require dotenv/config --import tsx scripts/worker.ts",
    "tokens:rotate": "node --require dotenv/config --import tsx scripts/rotate-token-encryption.ts",
    "tokens:encrypt-access": "node --require dotenv/config --import tsx scripts/encrypt-x-access-tokens.ts",
    "smoke:e2e": "node --require dotenv/config --import tsx scripts/smoke-e2e.ts",
    "smoke:full": "node --require dotenv/config --import tsx scripts/smoke-full.ts",
    "test:twitter-perms": "node --require dotenv/config --import tsx scripts/test-twitter-permissions.ts",
    "esbuild:rebuild": "pnpm rebuild esbuild",
    "build": "pnpm run db:migrate && next build",
    "build:ci": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "npx tsx scripts/setup.ts",
    "env:check": "node -e \"require('./src/lib/env.ts').checkEnv()\" || echo 'Run with tsx: npx tsx -e \"import { checkEnv } from './src/lib/env'; checkEnv();\"'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:dev": "drizzle-kit push",
    "db:reset": "drizzle-kit drop && drizzle-kit push",
    "sync-template": "node create-agentic-app/scripts/sync-templates.js",
    "test": "vitest run",
    "test:e2e:ui": "playwright test tests/e2e/dashboard-layout.e2e.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.125",
    "@bull-board/api": "^6.20.5",
